{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    },
    "_meta": {
      "title": "Load Image"
    }
  },
  "2": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    },
    "_meta": {
      "title": "Load 4x UltraSharp"
    }
  },
  "3": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": [
        "2",
        0
      ],
      "image": [
        "1",
        0
      ]
    },
    "_meta": {
      "title": "AI Upscale"
    }
  },
  "4": {
    "class_type": "ImageScale",
    "inputs": {
      "image": [
        "3",
        0
      ],
      "upscale_method": "lanczos",
      "width": 1536,
      "height": 1106,
      "crop": "disabled"
    },
    "_meta": {
      "title": "Downscale To Mobile Size"
    }
  },
  "5": {
    "class_type": "ImageSharpen",
    "inputs": {
      "image": [
        "4",
        0
      ],
      "sharpen_radius": 2,
      "sigma": 1,
      "alpha": 0.8
    },
    "_meta": {
      "title": "Sharpen Enhanced Image"
    }
  },
  "6": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "5",
        0
      ],
      "filename_prefix": "{{output_prefix}}"
    },
    "_meta": {
      "title": "Save Enhanced Image"
    }
  }
}
