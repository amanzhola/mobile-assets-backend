{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    },
    "_meta": {
      "title": "Load Source Image"
    }
  },
  "2": {
    "class_type": "ExpressionEditor",
    "inputs": {
      "rotate_pitch": 0,
      "rotate_yaw": 0,
      "rotate_roll": 0,
      "blink": 0,
      "eyebrow": 0,
      "wink": 0,
      "pupil_x": 0,
      "pupil_y": 0,
      "aaa": 0,
      "eee": 0,
      "woo": 0,
      "smile": "{{smile_value}}",
      "src_ratio": 1,
      "sample_ratio": 1,
      "sample_parts": "OnlyExpression",
      "crop_factor": 1.7,
      "src_image": [
        "1",
        0
      ]
    },
    "_meta": {
      "title": "Smile Expression Editor"
    }
  },
  "3": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "2",
        0
      ],
      "filename_prefix": "{{output_prefix}}"
    },
    "_meta": {
      "title": "Save Smile Edit"
    }
  }
}
